<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Step Tracker Live</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 20px; }
        header { text-align: center; margin-bottom: 20px; }
        h1 { color: #333; }
        .input-section { margin-bottom: 20px; }
        label { display: block; margin-bottom: 5px; }
        input, button { display: block; width: 100%; margin: 5px 0; }
        button { background-color: #4CAF50; color: white; border: none; padding: 8px 12px; cursor: pointer; border-radius: 4px; }
        canvas { max-width: 100%; height: 200px; margin-top: 20px; }
        .chart-section { text-align: center; }
    </style>
  
  
  <script type="application/ld+json">
{
  "@context": "urn:goose.ai:schema",
  "@type": "GooseApp",
  "name": "step-tracker-live",
  "description": "Tracks daily steps with real-time visualization and trend line chart for fitness monitoring.",
  "width": 800,
  "height": 600,
  "resizable": true,
  "mcpServers": [
    "apps"
  ]
}
  </script>
</head>
<body>
    <header>
        <h1>Step Tracker Live</h1>
    </header>
    <main>
        <section class="input-section">
            <label for="steps">Enter steps for today:</label>
            <input type="number" id="steps" min="0" value="0">
            <button type="button" id="add-step">Add Steps</button>
        </section>
        <section class="chart-section">
            <canvas id="stepChart" width="400" height="200"></canvas>
        </section>
    </main>
    <script>
        document.getElementById('add-step').addEventListener('click', function() {
            const steps = document.getElementById('steps').value;
            if (steps === '') return;
            if (isNaN(steps)) {
                alert('Please enter a valid number of steps');
                return;
            }
            const stepData = [
                {day: 1, steps: 8500},
                {day: 2, steps: 9200},
                {day: 3, steps: 10500},
                {day: 4, steps: 9000},
                {day: 5, steps: 11000}
            ];
            stepData.push({day: stepData.length + 1, steps: parseInt(steps)});
            drawChart(stepData);
        });
        function drawChart(data) {
            const ctx = document.getElementById('stepChart').getContext('2d');
            ctx.clearRect(0, 0, 400, 200);
            const days = data.map(d => d.day);
            const steps = data.map(d => d.steps);
            ctx.beginPath();
            ctx.moveTo(50, 150 - (steps[0] / 12) * 100);
            for (let i = 1; i < data.length; i++) {
                ctx.lineTo(50 + (i * 20), 150 - (steps[i] / 12) * 100);
            }
            ctx.strokeStyle = '#2196F3';
            ctx.lineWidth = 2;
            ctx.stroke();
        }
        // Initial chart
        drawChart([
            {day: 1, steps: 8500},
            {day: 2, steps: 9200},
            {day: 3, steps: 10500},
            {day: 4, steps: 9000},
            {day: 5, steps: 11000}
        ]);
    </script>
</body>
</html>