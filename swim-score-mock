<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Swim Score Mock</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.4; max-width: 800px; margin: 0 auto; padding: 20px; }
        .container { display: flex; flex-direction: column; gap: 20px; }
        .form-group { display: flex; flex-direction: column; gap: 8px; }
        label { font-weight: bold; }
        input { padding: 8px; border: 1px solid #ccc; border-radius: 4px; }
        button { padding: 10px 15px; background-color: #4CAF50; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; }
        button:hover { background-color: #45a049; }
        #leaderboard { margin-top: 20px; border: 1px solid #ddd; padding: 10px; border-radius: 4px; }
        .swimmer { margin: 5px 0; padding: 5px; display: flex; justify-content: space-between; }
        .swimmer-name { font-weight: bold; }
        .swimmer-time { color: #0d6efd; }
    </style>
  
  
  <script type="application/ld+json">
{
  "@context": "urn:goose.ai:schema",
  "@type": "GooseApp",
  "name": "swim-score-mock",
  "description": "Generate and track mock swimming competitions with leaderboards.",
  "width": 800,
  "height": 600,
  "resizable": true,
  "mcpServers": [
    "apps"
  ]
}
  </script>
</head>
<body>
    <h1>Swimming Competition Leaderboard</h1>
    <div class="container">
        <form id="swimmerForm">
            <div class="form-group">
                <label for="name">Swimmer Name</label>
                <input type="text" id="name" placeholder="Enter name">
            </div>
            <div class="form-group">
                <label for="time">Time (seconds)</label>
                <input type="number" id="time" placeholder="Enter time">
            </div>
            <button type="button" id="addSwimmerBtn">Add Swimmer</button>
            <button type="button" id="generateMockBtn">Generate Mock Competition</button>
        </form>
        <div id="leaderboard">Leaderboard will be displayed here</div>
    </div>

    <script>
        let swimmers = [];

        document.getElementById('addSwimmerBtn').addEventListener('click', function() {
            const name = document.getElementById('name').value;
            const time = parseFloat(document.getElementById('time').value);
            if (name && !isNaN(time)) {
                swimmers.push({ name, time });
                renderLeaderboard();
            }
        });

        document.getElementById('generateMockBtn').addEventListener('click', function() {
            // Generate 5 mock swimmers with random names and times
            const mockSwimmers = [];
            for (let i = 0; i < 5; i++) {
                const name = `Swimmer ${i+1}`;
                const time = Math.random() * 10 + 5; // 5 to 15 seconds
                mockSwimmers.push({ name, time });
            }
            swimmers = mockSwimmers;
            renderLeaderboard();
        });

        function renderLeaderboard() {
            const leaderboard = document.getElementById('leaderboard');
            leaderboard.innerHTML = '';
            swimmers.sort((a, b) => a.time - b.time);
            swimmers.forEach(swimmer => {
                const li = document.createElement('div');
                li.className = 'swimmer';
                li.innerHTML = `<span class="swimmer-name">${swimmer.name}</span> <span class="swimmer-time">${swimmer.time.toFixed(2)}s</span>`;
                leaderboard.appendChild(li);
            });
        }

        // Initialize with mock competition
        document.getElementById('generateMockBtn').click();
    </script>
</body>
</html>