<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Step Tracker Mock</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f5f5f5;
            color: #333;
            max-width: 800px;
            margin: 0 auto;
        }
        h1 {
            color: #2c3e50;
            text-align: center;
            margin-bottom: 15px;
        }
        .step-count {
            text-align: center;
            margin-bottom: 15px;
        }
        button {
            background-color: #3498db;
            color: white;
            padding: 10px 15px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        button:hover {
            background-color: #2980b9;
        }
        .step-history {
            margin-top: 20px;
        }
        h2 {
            color: #2c3e50;
            border-bottom: 1px solid #eee;
            padding-bottom: 5px;
        }
        ul {
            list-style-type: none;
            padding-left: 0;
        }
        li {
            padding: 8px 0;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
        }
        @media (max-width: 768px) {
            body {
                padding: 10px;
            }
            .step-count {
                text-align: center;
            }
        }
    </style>
  
  
  <script type="application/ld+json">
{
  "@context": "urn:goose.ai:schema",
  "@type": "GooseApp",
  "name": "step-tracker-mock",
  "description": "A step tracker that generates mock data for demonstration purposes.",
  "width": 800,
  "height": 600,
  "resizable": true,
  "mcpServers": [
    "apps"
  ]
}
  </script>
</head>
<body>
    <h1>Step Tracker</h1>
    <div class="step-count">
        <p>Today's Steps: <span id="current-steps">0</span></p>
    </div>
    <button id="add-steps">Add Steps</button>
    <div class="step-history">
        <h2>Step History</h2>
        <ul id="history-list"></ul>
    </div>
    <script>
        document.getElementById('add-steps').addEventListener('click', function() {
            let steps = parseInt(document.getElementById('current-steps').textContent) || 0;
            steps += 100;
            document.getElementById('current-steps').textContent = steps;

            const now = new Date();
            const timestamp = now.toLocaleString();
            const entry = document.createElement('li');
            entry.textContent = `${steps} steps at ${timestamp}`;
            document.getElementById('history-list').appendChild(entry);
        });
    </script>
</body>
</html>