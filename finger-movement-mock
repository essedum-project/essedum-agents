<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Finger Movement Mock</title>
    <style>
        body {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            font-family: sans-serif;
            max-width: 100vw;
            color: #333;
        }
        h1 {
            margin-bottom: 10px;
            color: #2c3e50;
        }
        #canvas-container {
            width: 100%;
            max-width: 800px;
            height: 400px;
            border: 1px solid #ccc;
            background-color: #fff;
            margin: 10px 0;
            position: relative;
        }
        #metrics {
            width: 300px;
            padding: 15px;
            background-color: #fff;
            border: 1px solid #ccc;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        #metrics p {
            margin: 5px 0;
            font-size: 14px;
        }
        #metrics span {
            font-weight: bold;
            color: #0066ff;
        }
    </style>
  
  
  <script type="application/ld+json">
{
  "@context": "urn:goose.ai:schema",
  "@type": "GooseApp",
  "name": "finger-movement-mock",
  "description": "Simulates real-time finger movements with mock data. Displays position and speed via live canvas animations.",
  "width": 800,
  "height": 600,
  "resizable": false,
  "mcpServers": [
    "apps"
  ]
}
  </script>
</head>
<body>
    <h1>Finger Movement Tracker</h1>
    <div id="canvas-container">
        <canvas id="movement-canvas"></canvas>
    </div>
    <div id="metrics">
        <p>X Position: <span id="x-pos">0</span></p>
        <p>Y Position: <span id="y-pos">0</span></p>
        <p>Speed: <span id="speed">0</span> px/frame</p>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('movement-canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth * 0.8;
            canvas.height = 400;
            
            let lastX = canvas.width / 2;
            let lastY = canvas.height / 2;
            let positions = [];
            let speed = 0;
            
            const animate = () => {
                // Generate new random position within canvas
                const newX = Math.random() * canvas.width;
                const newY = Math.random() * canvas.height;
                
                // Calculate speed
                const dx = newX - lastX;
                const dy = newY - lastY;
                speed = Math.sqrt(dx * dx + dy * dy);
                
                // Update last position
                lastX = newX;
                lastY = newY;
                
                // Clear canvas
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                
                // Draw path
                ctx.beginPath();
                ctx.moveTo(lastX, lastY);
                ctx.lineTo(newX, newY);
                ctx.strokeStyle = '#0066ff';
                ctx.lineWidth = 1;
                ctx.stroke();
                
                // Update UI
                document.getElementById('x-pos').textContent = newX.toFixed(1);
                document.getElementById('y-pos').textContent = newY.toFixed(1);
                document.getElementById('speed').textContent = speed.toFixed(2);
                
                // Request next frame
                requestAnimationFrame(animate);
            };
            
            // Initialize animation
            animate();
        });
    </script>
</body>
</html>