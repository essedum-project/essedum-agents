<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Step Counter</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Roboto', sans-serif;
            background-color: #f4f4f9;
            margin: 0;
            padding: 20px;
        }
        h1 {
            text-align: center;
            color: #333;
        }
        .container {
            max-width: 600px;
            margin: auto;
            background: white;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            padding: 20px;
        }
        .steps-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .steps-info div {
            background: #e7f3fe;
            border-radius: 5px;
            padding: 10px;
            flex: 1;
            margin: 0 10px;
            text-align: center;
        }
        .history {
            margin: 20px 0;
        }
        .history ul {
            list-style: none;
            padding: 0;
        }
        .history li {
            background: #fafafa;
            margin: 5px 0;
            padding: 10px;
            border-radius: 5px;
        }
        @media (max-width: 600px) {
            .steps-info {
                flex-direction: column;
            }
            .steps-info div {
                margin: 10px 0;
            }
        }
    </style>
  <script type="application/ld+json">
{
  "@context": "urn:goose.ai:schema",
  "@type": "GooseApp",
  "name": "daily-step-counter",
  "description": "Track daily steps with mock data and visualizations.",
  "width": 400,
  "height": 300,
  "resizable": false,
  "mcpServers": [
    "apps"
  ]
}
  </script>
  <script type="application/x-goose-prd">
Create a Step Tracker app that tracks steps with mock data. The app should display total steps, steps taken today, and a history of daily steps. Include a simple user interface with visualizations for the data.
  </script>
</head>
<body>
    <div class="container">
        <h1>Daily Step Counter</h1>
        <div class="steps-info">
            <div id="total-steps">Total Steps: <span>0</span></div>
            <div id="today-steps">Steps Today: <span>0</span></div>
        </div>
        <div class="history">
            <h3>Steps History</h3>
            <ul id="steps-history"></ul>
        </div>
    </div>
    <script>
        const totalStepsElement = document.getElementById('total-steps').querySelector('span');
        const todayStepsElement = document.getElementById('today-steps').querySelector('span');
        const historyElement = document.getElementById('steps-history');

        let totalSteps = 0;
        let todaySteps = Math.floor(Math.random() * 10000);
        const stepsData = [];

        function updateUI() {
            totalSteps += todaySteps;
            totalStepsElement.innerText = totalSteps;
            todayStepsElement.innerText = todaySteps;
            stepsData.push(todaySteps);
            renderHistory();
        }

        function renderHistory() {
            historyElement.innerHTML = '';
            stepsData.forEach((steps, index) => {
                const li = document.createElement('li');
                li.innerText = `Day ${index + 1}: ${steps} steps`;
                historyElement.appendChild(li);
            });
        }

        // Simulate a daily reset at midnight
        setInterval(() => {
            todaySteps = Math.floor(Math.random() * 10000);
            updateUI();
        }, 2000); // Update every 2 seconds for demo

        // Initial update
        updateUI();
    </script>
</body>
</html>