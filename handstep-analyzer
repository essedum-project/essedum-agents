<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Handstep Analyzer</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Roboto', sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            background-color: #f4f4f4;
            color: #333;
        }
        h1 {
            margin-bottom: 20px;
        }
        #controls {
            margin-bottom: 20px;
        }
        button {
            padding: 10px 20px;
            margin-right: 10px;
            background-color: #5cb85c;
            border: none;
            color: #fff;
            cursor: pointer;
            border-radius: 4px;
            transition: background-color 0.3s;
        }
        button:hover {
            background-color: #4cae4c;
        }
        #step-count, #result {
            margin: 20px 0;
            font-size: 24px;
        }
        #chart {
            width: 100%;
            height: 200px;
            margin-top: 20px;
        }
        @media (min-width: 600px) {
            body {
                width: 600px;
            }
        }
    </style>
  <script type="application/ld+json">
{
  "@context": "urn:goose.ai:schema",
  "@type": "GooseApp",
  "name": "handstep-analyzer",
  "description": "Track hand movements and analyze step counts with visualizations and statistics.",
  "width": 800,
  "height": 600,
  "resizable": false,
  "mcpServers": [
    "apps"
  ]
}
  </script>
  <script type="application/x-goose-prd">
Create a step tracker app that analyzes hand movements using mock data. The app should have features to display step counts, visualize hand movement patterns, and provide basic statistics on steps and movements over time.
  </script>
</head>
<body>
    <h1>Handstep Analyzer</h1>
    <div id="controls">
        <button id="analyze">Analyze Hand Movements</button>
        <button id="reset">Reset</button>
    </div>
    <div id="step-count">Step Count: 0</div>
    <canvas id="chart"></canvas>
    <div id="result"></div>
    <script>
        let stepCount = 0;
        let dataPoints = [];

        const analyzeButton = document.getElementById('analyze');
        const resetButton = document.getElementById('reset');
        const stepCountDisplay = document.getElementById('step-count');
        const resultDisplay = document.getElementById('result');
        const chart = document.getElementById('chart');
        const ctx = chart.getContext('2d');

        analyzeButton.addEventListener('click', () => {
            const mockData = generateMockData();
            stepCount += mockData.steps;
            dataPoints.push(mockData.steps);
            stepCountDisplay.textContent = `Step Count: ${stepCount}`;
            displayStatistics();
            renderChart();
        });

        resetButton.addEventListener('click', () => {
            stepCount = 0;
            dataPoints = [];
            stepCountDisplay.textContent = `Step Count: ${stepCount}`;
            resultDisplay.textContent = '';
            ctx.clearRect(0, 0, chart.width, chart.height);
        });

        function generateMockData() {
            return { steps: Math.floor(Math.random() * 10) + 1 };
        }

        function displayStatistics() {
            const average = stepCount / dataPoints.length;
            resultDisplay.textContent = `Average Steps: ${average.toFixed(2)}`;
        }

        function renderChart() {
            ctx.clearRect(0, 0, chart.width, chart.height);
            ctx.fillStyle = '#007bff';
            for (let i = 0; i < dataPoints.length; i++) {
                ctx.fillRect(i * 30, chart.height - dataPoints[i] * 10, 25, dataPoints[i] * 10);
            }
        }
    </script>
</body>
</html>